# LibreDash production environment example.
LIBREDASH_PRODUCTION=1
LIBREDASH_HOME=/var/lib/libredash
LIBREDASH_DATA_DIR=/path/to/data
LIBREDASH_DUCKLAKE_CATALOG_PATH=/var/lib/libredash/ducklake/catalog.sqlite

# Optional browser asset cache-bust override. Leave empty to use the generated build hash.
LIBREDASH_ASSET_VERSION=

# Use local browser auth for simple self-hosted deployments, API-token-only auth
# for bootstrap automation, or configure Azure/OIDC below.
LIBREDASH_LOCAL_AUTH=1
# LIBREDASH_API_TOKEN_ONLY_AUTH=1
LIBREDASH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# Required in production. Use 32+ characters.
LIBREDASH_CSRF_KEY=replace-with-at-least-32-characters

# Required for API-token-only production. Browser auth deployments also derive
# allowed hosts from callback URLs, but explicit values are recommended.
LIBREDASH_ALLOWED_HOSTS=libredash.example.com

# Required for production OIDC/Azure browser auth. API-token-only deployments may
# set false only when no browser session cookies are used.
LIBREDASH_COOKIE_SECURE=true

# Set true only when every request reaches LibreDash through a trusted reverse proxy
# that overwrites X-Forwarded-For/X-Real-IP.
LIBREDASH_TRUST_PROXY_HEADERS=false

# Optional SCIM provisioning endpoint bearer token. Required to be 32+ characters when set in production.
LIBREDASH_SCIM_BEARER_TOKEN=

# Required in production. Use 32+ characters. Send as Authorization: Bearer <token> when scraping /metrics.
LIBREDASH_METRICS_BEARER_TOKEN=replace-with-at-least-32-characters

# Interactive query execution limits.
LIBREDASH_EXEC_MAX_RUNNING_READS=4
LIBREDASH_EXEC_MAX_QUEUED_READS=64
LIBREDASH_EXEC_READ_QUEUE_TIMEOUT=30s
LIBREDASH_EXEC_READ_TIMEOUT=2m

# Azure AD / Entra ID auth.
# LIBREDASH_AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# LIBREDASH_AZURE_CLIENT_SECRET=replace-with-azure-client-secret
# LIBREDASH_AZURE_CALLBACK_URL=https://your-host/auth/azureadv2/callback
# LIBREDASH_AZURE_TENANT=00000000-0000-0000-0000-000000000000

# Generic OIDC auth.
# LIBREDASH_OIDC_PROVIDER_ID=oidc
# LIBREDASH_OIDC_ISSUER_URL=https://issuer.example.com
# LIBREDASH_OIDC_CLIENT_ID=replace-with-oidc-client-id
# LIBREDASH_OIDC_CLIENT_SECRET=replace-with-oidc-client-secret
# LIBREDASH_OIDC_CALLBACK_URL=https://your-host/auth/oidc/callback
# LIBREDASH_OIDC_SCOPES=openid profile email
