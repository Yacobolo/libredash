# Assets
# LIBREDASH_ASSET_VERSION=

# Authentication
# LIBREDASH_API_TOKEN_ONLY_AUTH=true
# LIBREDASH_AZURE_CALLBACK_URL=https://libredash.example.com/auth/azureadv2/callback
# LIBREDASH_AZURE_CLIENT_ID=
# LIBREDASH_AZURE_CLIENT_SECRET=replace-with-secret
# LIBREDASH_AZURE_TENANT=
# LIBREDASH_DEV_AUTH_BYPASS=false
LIBREDASH_LOCAL_AUTH=true
# LIBREDASH_OIDC_CALLBACK_URL=https://libredash.example.com/auth/oidc/callback
# LIBREDASH_OIDC_CLIENT_ID=
# LIBREDASH_OIDC_CLIENT_SECRET=replace-with-secret
