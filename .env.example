# Administration
LIBREDASH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# Agent
# LIBREDASH_AGENT_API_KEY=replace-with-secret
# LIBREDASH_AGENT_BASE_URL=https://api.openai.com/v1
