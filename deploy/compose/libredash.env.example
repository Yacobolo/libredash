LIBREDASH_PRODUCTION=1
LIBREDASH_ENVIRONMENT=prod
LIBREDASH_ADDR=:8080
LIBREDASH_HOME=/var/lib/libredash/home
LIBREDASH_MANAGED_DATA_BACKEND=local
LIBREDASH_MANAGED_DATA_DIR=/var/lib/libredash/home/managed-data
LIBREDASH_LOCAL_AUTH=1
LIBREDASH_COOKIE_SECURE=true
LIBREDASH_TRUST_PROXY_HEADERS=true
LIBREDASH_ALLOWED_HOSTS=dash.example.com
LIBREDASH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
LIBREDASH_CSRF_KEY=<generated-by-libredashctl>
LIBREDASH_METRICS_BEARER_TOKEN=<generated-by-libredashctl>
