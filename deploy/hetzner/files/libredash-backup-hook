#!/usr/bin/env bash
set -euo pipefail

archive="${1:?backup archive is required}"
backup_dir="$(dirname -- "$archive")"
restic_env=/etc/libredash/restic.env

if [[ -s "$restic_env" ]]; then
  command -v restic >/dev/null 2>&1 || { printf 'restic.env is configured but restic is unavailable\n' >&2; exit 1; }
  set -a
  # shellcheck disable=SC1090
  source "$restic_env"
  set +a
  restic snapshots >/dev/null 2>&1 || restic init
  restic backup "$archive" "$archive.sha256" --tag libredash
  restic forget --tag libredash --keep-daily 7 --keep-weekly 4 --keep-monthly 12 --prune
fi

find "$backup_dir" -maxdepth 1 -type f -name 'libredash-*.tar.gz' -print \
  | sort -r \
  | awk 'NR > 7' \
  | while IFS= read -r stale; do
      rm -f -- "$stale" "$stale.sha256"
    done
