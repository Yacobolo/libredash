{
  "name": "libredash",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:css && npm run build:route-entrypoints && npm run build:support-entrypoints",
    "build:css": "tailwindcss -i ./static/app.input.css -o ./static/app.css",
    "build:route-entrypoints": "npm run build:app-shell && npm run build:catalog-page && npm run build:dashboard-page && npm run build:workspace-page && npm run build:chat-page && npm run build:admin-page && npm run build:login-page && npm run build:inspector",
    "build:support-entrypoints": "npm run build:url-sync && npm run build:login-background && npm run build:asset-lineage",
    "build:app-shell": "esbuild web/components/app/app-shell.ts --bundle --format=esm --outfile=static/app-shell.js",
    "build:catalog-page": "esbuild web/components/app/catalog-page.ts --bundle --format=esm --outfile=static/catalog-page.js",
    "build:dashboard-page": "esbuild web/components/dashboard/dashboard-page.ts --bundle --format=esm --splitting --outdir=static --entry-names=dashboard-page --chunk-names=chunks/dashboard-[name]-[hash]",
    "build:workspace-page": "esbuild web/components/workspace/workspace-page.ts --bundle --format=esm --outfile=static/workspace-page.js",
    "build:chat-page": "esbuild web/components/chat/chat-page.ts --bundle --format=esm --outfile=static/chat-page.js",
    "build:admin-page": "esbuild web/components/admin/admin-page.ts --bundle --format=esm --outfile=static/admin-page.js",
    "build:login-page": "esbuild web/components/login/login-page.ts --bundle --format=esm --outfile=static/login-page.js",
    "build:url-sync": "esbuild web/components/dashboard/filters/url-sync.ts --bundle --format=esm --outfile=static/url-sync.js",
    "build:inspector": "esbuild web/components/inspector/index.ts --bundle --format=esm --outfile=static/datastar-inspector.js",
    "build:login-background": "esbuild web/components/login/topology-background.ts --bundle --format=esm --outfile=static/topology-background.js",
    "build:asset-lineage": "esbuild web/components/shared/asset-lineage-graph.ts --bundle --format=esm --outfile=static/asset-lineage-graph.js",
    "watch:css": "tailwindcss -i ./static/app.input.css -o ./static/app.css --watch",
    "test:theme": "mkdir -p .tmp && esbuild static/theme.dom.test.ts --bundle --platform=node --format=esm --external:@playwright/test --outfile=.tmp/theme.dom.test.mjs && node --test .tmp/theme.dom.test.mjs",
    "test:app-shell": "mkdir -p .tmp/app-shell-test && esbuild web/components/app/app-shell.ts --bundle --format=esm --outfile=.tmp/app-shell-test/app-shell-under-test.js && esbuild web/components/app/app-shell.dom.test.ts --bundle --platform=node --format=esm --external:@playwright/test --outfile=.tmp/app-shell.dom.test.mjs && node --test .tmp/app-shell.dom.test.mjs",
    "test:table-selection": "mkdir -p .tmp && esbuild web/components/dashboard/table/selection.test.ts --bundle --platform=node --format=esm --outfile=.tmp/table-selection.test.mjs && node --test .tmp/table-selection.test.mjs",
    "test:visual-modal": "mkdir -p .tmp && npx playwright install chromium && esbuild web/components/dashboard/visual-modal.ts --bundle --format=esm --outfile=.tmp/visual-modal-under-test.js && esbuild web/components/dashboard/visual-modal-focus.test.ts --bundle --platform=node --format=esm --outfile=.tmp/visual-modal-focus.test.mjs && esbuild web/components/dashboard/visual-modal.dom.test.ts --bundle --platform=node --format=esm --external:@playwright/test --outfile=.tmp/visual-modal.dom.test.mjs && node --test .tmp/visual-modal-focus.test.mjs .tmp/visual-modal.dom.test.mjs",
    "test:catalog-page": "mkdir -p .tmp/catalog-page-test && esbuild web/components/app/catalog-page.ts --bundle --format=esm --outfile=.tmp/catalog-page-test/catalog-page-under-test.js && esbuild web/components/app/catalog-page.dom.test.ts --bundle --platform=node --format=esm --external:@playwright/test --outfile=.tmp/catalog-page.dom.test.mjs && node --test .tmp/catalog-page.dom.test.mjs",
    "test:dashboard-page": "mkdir -p .tmp/dashboard-page-test && esbuild web/components/dashboard/dashboard-page.ts --bundle --format=esm --splitting --outdir=.tmp/dashboard-page-test --entry-names=dashboard-page-under-test --chunk-names=chunks/[name]-[hash] && esbuild web/components/dashboard/dashboard-page.dom.test.ts --bundle --platform=node --format=esm --external:@playwright/test --outfile=.tmp/dashboard-page.dom.test.mjs && node --test .tmp/dashboard-page.dom.test.mjs",
    "test:chat-page": "mkdir -p .tmp/chat-page-test && esbuild web/components/chat/chat-page.ts --bundle --format=esm --outfile=.tmp/chat-page-test/chat-page-under-test.js && esbuild web/components/chat/chat-page.dom.test.ts --bundle --platform=node --format=esm --external:@playwright/test --outfile=.tmp/chat-page.dom.test.mjs && node --test .tmp/chat-page.dom.test.mjs",
    "test:workspace-page": "mkdir -p .tmp/workspace-page-test && esbuild web/components/workspace/workspace-page.ts --bundle --format=esm --outfile=.tmp/workspace-page-test/workspace-page-under-test.js && esbuild web/components/workspace/workspace-page.dom.test.ts --bundle --platform=node --format=esm --external:@playwright/test --outfile=.tmp/workspace-page.dom.test.mjs && node --test .tmp/workspace-page.dom.test.mjs",
    "test:admin-page": "mkdir -p .tmp/admin-page-test && esbuild web/components/admin/admin-page.ts --bundle --format=esm --outfile=.tmp/admin-page-test/admin-page-under-test.js && esbuild web/components/admin/admin-page.dom.test.ts --bundle --platform=node --format=esm --external:@playwright/test --outfile=.tmp/admin-page.dom.test.mjs && node --test .tmp/admin-page.dom.test.mjs",
    "test:login-page": "mkdir -p .tmp/login-page-test && esbuild web/components/login/login-page.ts --bundle --format=esm --outfile=.tmp/login-page-test/login-page-under-test.js && esbuild web/components/login/login-page.dom.test.ts --bundle --platform=node --format=esm --external:@playwright/test --outfile=.tmp/login-page.dom.test.mjs && node --test .tmp/login-page.dom.test.mjs",
    "test:asset-lineage": "mkdir -p .tmp/asset-lineage-test && esbuild web/components/shared/asset-lineage-graph.ts --bundle --format=esm --outfile=.tmp/asset-lineage-test/asset-lineage-graph-under-test.js && esbuild web/components/shared/asset-lineage-graph.dom.test.ts --bundle --platform=node --format=esm --external:@playwright/test --outfile=.tmp/asset-lineage-graph.dom.test.mjs && node --test .tmp/asset-lineage-graph.dom.test.mjs"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@playwright/test": "^1.61.1",
    "@primer/primitives": "11.9.0",
    "@tailwindcss/cli": "4.3.1",
    "@tanstack/lit-table": "^9.0.0-beta.12",
    "@tanstack/lit-virtual": "^3.13.29",
    "@tanstack/table-core": "^9.0.0-beta.12",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@xyflow/react": "^12.11.0",
    "echarts": "^6.1.0",
    "esbuild": "^0.28.1",
    "lit": "^3.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "4.3.1"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "lucide": "^1.21.0",
    "markdown-it": "^14.2.0",
    "p5": "^1.11.13",
    "shiki": "^4.2.0"
  }
}
