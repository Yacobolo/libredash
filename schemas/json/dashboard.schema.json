{
  "$defs": {
    "#APIVersion": {
      "const": "leapview.dev/v1"
    },
    "#AnyObject": {
      "additionalProperties": true,
      "type": "object"
    },
    "#CartesianPresentation": {
      "$ref": "#/$defs/%23PresentationCommon",
      "additionalProperties": false,
      "properties": {
        "area": {
          "type": "boolean"
        },
        "data_zoom": {
          "type": "boolean"
        },
        "dual_axis": {
          "type": "boolean"
        },
        "histogram_bins": {
          "allOf": [
            {
              "type": "number"
            },
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            }
          ]
        },
        "label_position": {
          "enum": [
            "automatic",
            "inside",
            "outside",
            "top"
          ]
        },
        "orientation": {
          "enum": [
            "horizontal",
            "vertical"
          ]
        },
        "series_types": {
          "additionalProperties": {
            "enum": [
              "line",
              "area",
              "bar",
              "column"
            ]
          },
          "type": "object"
        },
        "show_symbols": {
          "type": "boolean"
        },
        "smooth": {
          "type": "boolean"
        },
        "stacked": {
          "type": "boolean"
        },
        "step": {
          "type": "boolean"
        },
        "symbol_size": {
          "exclusiveMinimum": 0,
          "type": "number"
        }
      },
      "type": "object"
    },
    "#CartesianVisual": {
      "$ref": "#/$defs/%23VisualCommon",
      "additionalProperties": false,
      "properties": {
        "presentation": {
          "$ref": "#/$defs/%23CartesianPresentation"
        },
        "query": {
          "$ref": "#/$defs/%23VisualQuery"
        },
        "type": {
          "enum": [
            "line",
            "area",
            "bar",
            "column",
            "scatter",
            "heatmap",
            "candlestick",
            "boxplot",
            "combo",
            "waterfall",
            "histogram"
          ]
        }
      },
      "required": [
        "query",
        "type"
      ],
      "type": "object"
    },
    "#CustomVisual": {
      "$ref": "#/$defs/%23VisualCommon",
      "additionalProperties": false,
      "properties": {
        "custom": {
          "additionalProperties": false,
          "properties": {
            "engine": {
              "const": "vega_lite"
            },
            "program": {
              "$ref": "#/$defs/%23AnyObject"
            }
          },
          "required": [
            "engine",
            "program"
          ],
          "type": "object"
        },
        "query": {
          "$ref": "#/$defs/%23VisualQuery"
        },
        "type": {
          "const": "custom"
        }
      },
      "required": [
        "custom",
        "query",
        "type"
      ],
      "type": "object"
    },
    "#DashboardSpec": {
      "additionalProperties": false,
      "properties": {
        "filters": {
          "additionalProperties": false,
          "patternProperties": {
            "^[A-Za-z_][A-Za-z0-9_]*$": {
              "$ref": "#/$defs/%23Filter"
            }
          },
          "type": "object"
        },
        "pages": {
          "items": {
            "$ref": "#/$defs/%23Page"
          },
          "minItems": 1,
          "type": "array"
        },
        "semanticModel": {
          "$ref": "#/$defs/%23Identifier"
        },
        "visuals": {
          "additionalProperties": false,
          "minProperties": 1,
          "patternProperties": {
            "^[A-Za-z_][A-Za-z0-9_]*$": {
              "$ref": "#/$defs/%23Visual"
            }
          },
          "type": "object"
        }
      },
      "required": [
        "pages",
        "semanticModel",
        "visuals"
      ],
      "type": "object"
    },
    "#DataTableVisual": {
      "$ref": "#/$defs/%23TabularVisualCommon",
      "additionalProperties": false,
      "properties": {
        "query": {
          "$ref": "#/$defs/%23TableQuery"
        },
        "type": {
          "const": "table"
        }
      },
      "required": [
        "query",
        "type"
      ],
      "type": "object"
    },
    "#FieldRef": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*\\.[A-Za-z_][A-Za-z0-9_]*$",
      "type": "string"
    },
    "#FieldRefObject": {
      "additionalProperties": false,
      "properties": {
        "alias": {
          "$ref": "#/$defs/%23Identifier"
        },
        "field": {
          "anyOf": [
            {
              "$ref": "#/$defs/%23FieldRef"
            },
            {
              "$ref": "#/$defs/%23Identifier"
            }
          ]
        }
      },
      "required": [
        "alias",
        "field"
      ],
      "type": "object"
    },
    "#FieldRefValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/%23FieldRef"
        },
        {
          "$ref": "#/$defs/%23Identifier"
        },
        {
          "$ref": "#/$defs/%23FieldRefObject"
        }
      ]
    },
    "#FieldRefs": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/%23FieldRefValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": false,
          "patternProperties": {
            "^[A-Za-z_][A-Za-z0-9_]*$": {
              "anyOf": [
                {
                  "anyOf": [
                    {
                      "$ref": "#/$defs/%23FieldRef"
                    },
                    {
                      "$ref": "#/$defs/%23Identifier"
                    }
                  ]
                },
                {
                  "additionalProperties": false,
                  "properties": {
                    "field": {
                      "anyOf": [
                        {
                          "$ref": "#/$defs/%23FieldRef"
                        },
                        {
                          "$ref": "#/$defs/%23Identifier"
                        }
                      ]
                    }
                  },
                  "required": [
                    "field"
                  ],
                  "type": "object"
                }
              ]
            }
          },
          "type": "object"
        }
      ]
    },
    "#Filter": {
      "additionalProperties": false,
      "properties": {
        "custom": {
          "type": "boolean"
        },
        "default": {
          "$ref": "#/$defs/%23FilterDefault"
        },
        "default_operator": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "fact": {
          "$ref": "#/$defs/%23Identifier"
        },
        "field": {
          "anyOf": [
            {
              "$ref": "#/$defs/%23FieldRef"
            },
            {
              "$ref": "#/$defs/%23Identifier"
            }
          ]
        },
        "from_url_param": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "operator": {
          "type": "string"
        },
        "operator_url_param": {
          "type": "string"
        },
        "operators": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "options": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "label": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            },
            "required": [
              "label",
              "value"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "presets": {
          "items": {
            "$ref": "#/$defs/%23FilterPreset"
          },
          "type": "array"
        },
        "targets": {
          "additionalProperties": false,
          "properties": {
            "visuals": {
              "items": {
                "$ref": "#/$defs/%23Identifier"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "to_url_param": {
          "type": "string"
        },
        "type": {
          "enum": [
            "date_range",
            "multi_select",
            "text"
          ]
        },
        "url_param": {
          "type": "string"
        },
        "values": {
          "additionalProperties": false,
          "properties": {
            "limit": {
              "type": "integer"
            },
            "source": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "required": [
        "field",
        "label",
        "type"
      ],
      "type": "object"
    },
    "#FilterComponent": {
      "$ref": "#/$defs/%23PageComponentCommon",
      "additionalProperties": false,
      "properties": {
        "filter": {
          "$ref": "#/$defs/%23Identifier"
        },
        "kind": {
          "const": "filter"
        }
      },
      "required": [
        "filter",
        "kind"
      ],
      "type": "object"
    },
    "#FilterDefault": {
      "additionalProperties": false,
      "properties": {
        "from": {
          "type": "string"
        },
        "operator": {
          "type": "string"
        },
        "preset": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "values": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "#FilterPreset": {
      "additionalProperties": false,
      "properties": {
        "from": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "relative_days": {
          "type": "integer"
        },
        "to": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "label",
        "value"
      ],
      "type": "object"
    },
    "#GeographicLayer": {
      "anyOf": [
        {
          "$ref": "#/$defs/%23GeographicLayerCommon",
          "additionalProperties": false,
          "properties": {
            "geometry_asset": {
              "$ref": "#/$defs/%23Identifier"
            },
            "join": {
              "$ref": "#/$defs/%23Identifier"
            },
            "kind": {
              "const": "choropleth"
            }
          },
          "required": [
            "geometry_asset",
            "join",
            "kind"
          ],
          "type": "object"
        },
        {
          "$ref": "#/$defs/%23GeographicLayerCommon",
          "additionalProperties": false,
          "properties": {
            "cluster": {
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "max_zoom": {
                  "allOf": [
                    {
                      "type": "number"
                    },
                    {
                      "maximum": 24,
                      "minimum": 0,
                      "type": "integer"
                    }
                  ]
                },
                "minimum_points": {
                  "allOf": [
                    {
                      "type": "number"
                    },
                    {
                      "minimum": 2,
                      "type": "integer"
                    }
                  ]
                },
                "radius": {
                  "allOf": [
                    {
                      "type": "number"
                    },
                    {
                      "exclusiveMinimum": 0,
                      "type": "integer"
                    }
                  ]
                },
                "show_count": {
                  "type": "boolean"
                }
              },
              "type": "object"
            },
            "kind": {
              "const": "point"
            },
            "latitude": {
              "$ref": "#/$defs/%23Identifier"
            },
            "longitude": {
              "$ref": "#/$defs/%23Identifier"
            },
            "size": {
              "additionalProperties": false,
              "properties": {
                "domain_maximum": {
                  "type": "number"
                },
                "domain_minimum": {
                  "type": "number"
                },
                "maximum_radius": {
                  "minimum": 0,
                  "type": "number"
                },
                "minimum_radius": {
                  "minimum": 0,
                  "type": "number"
                }
              },
              "type": "object"
            }
          },
          "required": [
            "kind",
            "latitude",
            "longitude"
          ],
          "type": "object"
        },
        {
          "$ref": "#/$defs/%23GeographicLayerCommon",
          "additionalProperties": false,
          "properties": {
            "heat": {
              "additionalProperties": false,
              "properties": {
                "intensity": {
                  "exclusiveMinimum": 0,
                  "type": "number"
                },
                "radius": {
                  "exclusiveMinimum": 0,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "kind": {
              "anyOf": [
                {
                  "const": "heat"
                },
                {
                  "const": "density"
                }
              ]
            },
            "latitude": {
              "$ref": "#/$defs/%23Identifier"
            },
            "longitude": {
              "$ref": "#/$defs/%23Identifier"
            }
          },
          "required": [
            "kind",
            "latitude",
            "longitude"
          ],
          "type": "object"
        },
        {
          "$ref": "#/$defs/%23GeographicLayerCommon",
          "additionalProperties": false,
          "properties": {
            "geometry_asset": {
              "$ref": "#/$defs/%23Identifier"
            },
            "kind": {
              "const": "reference"
            }
          },
          "required": [
            "geometry_asset",
            "kind"
          ],
          "type": "object"
        },
        {
          "$ref": "#/$defs/%23GeographicLayerCommon",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "path"
            },
            "latitude": {
              "$ref": "#/$defs/%23Identifier"
            },
            "line": {
              "additionalProperties": false,
              "properties": {
                "curvature": {
                  "maximum": 1,
                  "minimum": 0,
                  "type": "number"
                },
                "width": {
                  "exclusiveMinimum": 0,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "longitude": {
              "$ref": "#/$defs/%23Identifier"
            },
            "order": {
              "$ref": "#/$defs/%23Identifier"
            },
            "path": {
              "$ref": "#/$defs/%23Identifier"
            }
          },
          "required": [
            "kind",
            "latitude",
            "longitude",
            "order",
            "path"
          ],
          "type": "object"
        }
      ]
    },
    "#GeographicLayerCommon": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "$ref": "#/$defs/%23Identifier"
        },
        "color": {
          "additionalProperties": false,
          "properties": {
            "domain_maximum": {
              "type": "number"
            },
            "domain_midpoint": {
              "type": "number"
            },
            "domain_minimum": {
              "type": "number"
            },
            "kind": {
              "enum": [
                "sequential",
                "diverging",
                "categorical"
              ]
            },
            "null_color": {
              "type": "string"
            },
            "palette": {
              "$ref": "#/$defs/%23Identifier"
            },
            "reverse": {
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "id": {
          "$ref": "#/$defs/%23Identifier"
        },
        "label": {
          "$ref": "#/$defs/%23Identifier"
        },
        "opacity": {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        "position": {
          "enum": [
            "below_labels",
            "above_labels"
          ]
        },
        "stroke": {
          "additionalProperties": false,
          "properties": {
            "color": {
              "type": "string"
            },
            "opacity": {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            "width": {
              "minimum": 0,
              "type": "number"
            }
          },
          "type": "object"
        },
        "tooltip": {
          "items": {
            "$ref": "#/$defs/%23Identifier"
          },
          "type": "array"
        },
        "value": {
          "$ref": "#/$defs/%23Identifier"
        },
        "visibility": {
          "additionalProperties": false,
          "properties": {
            "max_zoom": {
              "maximum": 24,
              "minimum": 0,
              "type": "number"
            },
            "min_zoom": {
              "maximum": 24,
              "minimum": 0,
              "type": "number"
            }
          },
          "type": "object"
        }
      },
      "required": [
        "id"
      ],
      "type": "object"
    },
    "#GeographicVisual": {
      "$ref": "#/$defs/%23VisualCommon",
      "additionalProperties": false,
      "properties": {
        "geo": {
          "additionalProperties": false,
          "properties": {
            "basemap": {
              "anyOf": [
                {
                  "$ref": "#/$defs/%23Identifier"
                },
                {
                  "const": "blank"
                }
              ]
            },
            "camera": {
              "additionalProperties": false,
              "properties": {
                "center": {
                  "maxLength": 2,
                  "minItems": 2,
                  "prefixItems": [
                    {
                      "type": "number"
                    },
                    {
                      "type": "number"
                    }
                  ],
                  "type": "array"
                },
                "max_zoom": {
                  "maximum": 24,
                  "minimum": 0,
                  "type": "number"
                },
                "min_zoom": {
                  "maximum": 24,
                  "minimum": 0,
                  "type": "number"
                },
                "mode": {
                  "enum": [
                    "fit_data",
                    "fixed",
                    "preserve"
                  ]
                },
                "padding": {
                  "allOf": [
                    {
                      "type": "number"
                    },
                    {
                      "minimum": 0,
                      "type": "integer"
                    }
                  ]
                },
                "zoom": {
                  "maximum": 24,
                  "minimum": 0,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "controls": {
              "additionalProperties": false,
              "properties": {
                "compass": {
                  "type": "boolean"
                },
                "reset": {
                  "type": "boolean"
                },
                "zoom": {
                  "type": "boolean"
                }
              },
              "type": "object"
            },
            "label_density": {
              "enum": [
                "hidden",
                "normal",
                "dense"
              ]
            },
            "layers": {
              "items": {
                "$ref": "#/$defs/%23GeographicLayer"
              },
              "minItems": 1,
              "prefixItems": [
                {
                  "$ref": "#/$defs/%23GeographicLayer"
                }
              ],
              "type": "array"
            },
            "theme": {
              "enum": [
                "auto",
                "light",
                "dark"
              ]
            }
          },
          "required": [
            "layers"
          ],
          "type": "object"
        },
        "presentation": {
          "additionalProperties": false,
          "properties": {
            "legend": {
              "enum": [
                "hidden",
                "top",
                "right",
                "bottom",
                "left"
              ]
            },
            "show_labels": {
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "query": {
          "$ref": "#/$defs/%23VisualQuery"
        },
        "type": {
          "const": "map"
        }
      },
      "required": [
        "geo",
        "query",
        "type"
      ],
      "type": "object"
    },
    "#HeaderComponent": {
      "$ref": "#/$defs/%23PageComponentCommon",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "header"
        }
      },
      "required": [
        "kind"
      ],
      "type": "object"
    },
    "#HierarchyPresentation": {
      "$ref": "#/$defs/%23PresentationCommon",
      "additionalProperties": false,
      "properties": {
        "breadcrumb": {
          "type": "boolean"
        },
        "curveness": {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        "focus": {
          "enum": [
            "none",
            "adjacency"
          ]
        },
        "initial_depth": {
          "allOf": [
            {
              "type": "number"
            },
            {
              "minimum": 0,
              "type": "integer"
            }
          ]
        },
        "layout": {
          "enum": [
            "standard",
            "circular"
          ]
        },
        "node_gap": {
          "minimum": 0,
          "type": "number"
        },
        "orientation": {
          "enum": [
            "horizontal",
            "vertical"
          ]
        },
        "roam": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "#HierarchyVisual": {
      "$ref": "#/$defs/%23VisualCommon",
      "additionalProperties": false,
      "properties": {
        "presentation": {
          "$ref": "#/$defs/%23HierarchyPresentation"
        },
        "query": {
          "$ref": "#/$defs/%23VisualQuery"
        },
        "type": {
          "enum": [
            "treemap",
            "sankey",
            "graph",
            "tree",
            "sunburst"
          ]
        }
      },
      "required": [
        "query",
        "type"
      ],
      "type": "object"
    },
    "#Identifier": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
      "type": "string"
    },
    "#Interaction": {
      "additionalProperties": false,
      "properties": {
        "point_selection": {
          "$ref": "#/$defs/%23SelectionInteraction"
        },
        "row_selection": {
          "$ref": "#/$defs/%23SelectionInteraction"
        },
        "spatial_selection": {
          "$ref": "#/$defs/%23SpatialSelectionInteraction"
        }
      },
      "type": "object"
    },
    "#KPIVisual": {
      "$ref": "#/$defs/%23VisualCommon",
      "additionalProperties": false,
      "properties": {
        "presentation": {
          "$ref": "#/$defs/%23KPIVisualPresentation"
        },
        "query": {
          "$ref": "#/$defs/%23VisualQuery"
        },
        "type": {
          "const": "kpi"
        }
      },
      "required": [
        "query",
        "type"
      ],
      "type": "object"
    },
    "#KPIVisualPresentation": {
      "additionalProperties": false,
      "properties": {
        "note": {
          "type": "string"
        },
        "thresholds": {
          "items": {
            "$ref": "#/$defs/%23Threshold"
          },
          "type": "array"
        },
        "tone": {
          "enum": [
            "neutral",
            "ink",
            "success",
            "warning",
            "danger"
          ]
        }
      },
      "type": "object"
    },
    "#MatrixVisual": {
      "$ref": "#/$defs/%23TabularVisualCommon",
      "additionalProperties": false,
      "properties": {
        "query": {
          "$ref": "#/$defs/%23TableQuery"
        },
        "type": {
          "const": "matrix"
        }
      },
      "required": [
        "query",
        "type"
      ],
      "type": "object"
    },
    "#MeasureRefs": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/%23FieldRefValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": false,
          "patternProperties": {
            "^[A-Za-z_][A-Za-z0-9_]*$": {
              "anyOf": [
                {
                  "type": "null"
                },
                {
                  "additionalProperties": false,
                  "properties": {
                    "measure": {
                      "$ref": "#/$defs/%23Identifier"
                    }
                  },
