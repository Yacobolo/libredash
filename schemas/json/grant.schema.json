{
  "$defs": {
    "#APIVersion": {
      "const": "leapview.dev/v1"
    },
    "#AccessSubject": {
      "additionalProperties": false,
      "properties": {
        "displayName": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "group": {
          "$ref": "#/$defs/%23ResourceID"
        },
        "kind": {
          "enum": [
            "principal",
            "group",
            "service_principal"
          ]
        },
        "principalId": {
          "$ref": "#/$defs/%23ResourceID"
        }
      },
      "required": [
        "kind"
      ],
      "type": "object"
    },
    "#Metadata": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/%23ResourceID"
        },
        "owner": {
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "title": {
          "type": "string"
        },
        "workspace": {
          "$ref": "#/$defs/%23ResourceID"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "#Privilege": {
      "enum": [
        "USE_WORKSPACE",
        "VIEW_ITEM",
        "EDIT_ITEM",
        "MANAGE_ITEM",
        "QUERY_DATA",
        "PREVIEW_DATA",
        "REFRESH_DATA",
        "DEPLOY",
        "ACTIVATE_DEPLOYMENT",
        "USE_AGENT",
        "VIEW_AGENT",
        "MANAGE_GRANTS",
        "VIEW_AUDIT",
        "MANAGE_WORKSPACE",
        "MANAGE_PLATFORM"
      ]
    },
    "#ResourceID": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$",
      "type": "string"
    },
    "#SecurableObjectRef": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "enum": [
            "workspace",
            "dashboard",
            "semantic_model",
            "source",
            "model_table",
            "dataset",
            "table",
            "column"
          ]
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "$ref": "#/$defs/%23APIVersion"
    },
    "kind": {
      "const": "Grant"
    },
    "metadata": {
      "$ref": "#/$defs/%23Metadata"
    },
    "spec": {
      "additionalProperties": false,
      "properties": {
        "object": {
          "$ref": "#/$defs/%23SecurableObjectRef"
        },
        "privilege": {
          "$ref": "#/$defs/%23Privilege"
        },
        "subject": {
          "$ref": "#/$defs/%23AccessSubject"
        }
      },
      "required": [
        "object",
        "privilege",
        "subject"
      ],
      "type": "object"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
