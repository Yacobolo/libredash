{
  "$defs": {
    "#APIVersion": {
      "const": "leapview.dev/v1"
    },
    "#IncludeList": {
      "additionalProperties": false,
      "properties": {
        "include": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "include"
      ],
      "type": "object"
    },
    "#Metadata": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/%23ResourceID"
        },
        "owner": {
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "title": {
          "type": "string"
        },
        "workspace": {
          "$ref": "#/$defs/%23ResourceID"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "#ResourceID": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "$ref": "#/$defs/%23APIVersion"
    },
    "kind": {
      "const": "Project"
    },
    "metadata": {
      "$ref": "#/$defs/%23Metadata"
    },
    "spec": {
      "additionalProperties": false,
      "properties": {
        "connections": {
          "$ref": "#/$defs/%23IncludeList"
        },
        "sources": {
          "$ref": "#/$defs/%23IncludeList"
        },
        "workspaces": {
          "$ref": "#/$defs/%23IncludeList"
        }
      },
      "required": [
        "connections",
        "sources",
        "workspaces"
      ],
      "type": "object"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
