{
  "$defs": {
    "#APIVersion": {
      "const": "libredash.dev/v1"
    },
    "#AnyObject": {
      "additionalProperties": true,
      "type": "object"
    },
    "#Connection": {
      "additionalProperties": false,
      "properties": {
        "credentials": {
          "anyOf": [
            {
              "$ref": "#/$defs/%23NoCredentials"
            },
            {
              "$ref": "#/$defs/%23EnvCredentials"
            }
          ]
        },
        "database": {
          "type": "string"
        },
        "defaults": {
          "additionalProperties": false,
          "properties": {
            "options": {
              "$ref": "#/$defs/%23AnyObject"
            }
          },
          "type": "object"
        },
        "description": {
          "type": "string"
        },
        "host": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "local",
            "s3",
            "r2",
            "gcs",
            "http",
            "azure_blob",
            "postgres",
            "mysql",
            "sqlite",
            "ducklake",
            "quack"
          ]
        },
        "options": {
          "$ref": "#/$defs/%23AnyObject"
        },
        "path": {
          "type": "string"
        },
        "port": {
          "type": "integer"
        },
        "root": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "sslMode": {
          "type": "string"
        },
        "username": {
          "type": "string"
        }
      },
      "required": [
        "kind"
      ],
      "type": "object"
    },
    "#EnvCredentials": {
      "additionalProperties": false,
      "properties": {
        "provider": {
          "const": "env"
        },
        "secret": {
          "type": "string"
        }
      },
      "required": [
        "provider",
        "secret"
      ],
      "type": "object"
    },
    "#Metadata": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/%23ResourceID"
        },
        "owner": {
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "title": {
          "type": "string"
        },
        "workspace": {
          "$ref": "#/$defs/%23ResourceID"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "#NoCredentials": {
      "const": {
        "provider": "none"
      }
    },
    "#ResourceID": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "$ref": "#/$defs/%23APIVersion"
    },
    "kind": {
      "const": "Connection"
    },
    "metadata": {
      "$ref": "#/$defs/%23Metadata"
    },
    "spec": {
      "$ref": "#/$defs/%23Connection"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
