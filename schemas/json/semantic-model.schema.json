{
  "$defs": {
    "#APIVersion": {
      "const": "leapview.dev/v1"
    },
    "#FieldRef": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*\\.[A-Za-z_][A-Za-z0-9_]*$",
      "type": "string"
    },
    "#Identifier": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
      "type": "string"
    },
    "#Measure": {
      "additionalProperties": false,
      "properties": {
        "aggregation": {
          "enum": [
            "sum",
            "count",
            "count_distinct",
            "avg",
            "min",
            "max"
          ]
        },
        "description": {
          "type": "string"
        },
        "empty": {
          "enum": [
            "zero",
            "null"
          ]
        },
        "fact": {
          "$ref": "#/$defs/%23Identifier"
        },
        "filters": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "field": {
                "$ref": "#/$defs/%23FieldRef"
              },
              "operator": {
                "enum": [
                  "equals",
                  "in",
                  "contains",
                  "starts_with",
                  "greater_than_or_equal",
                  "less_than"
                ]
              },
              "values": {
                "type": "array"
              }
            },
            "required": [
              "field",
              "operator",
              "values"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "format": {
          "type": "string"
        },
        "hidden": {
          "type": "boolean"
        },
        "input": {
          "additionalProperties": false,
          "properties": {
            "expression": {
              "type": "string"
            },
            "field": {
              "$ref": "#/$defs/%23FieldRef"
            }
          },
          "type": "object"
        },
        "label": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        }
      },
      "required": [
        "aggregation",
        "empty",
        "fact"
      ],
      "type": "object"
    },
    "#Metadata": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/%23ResourceID"
        },
        "owner": {
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "title": {
          "type": "string"
        },
        "workspace": {
          "$ref": "#/$defs/%23ResourceID"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "#Metric": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "expression": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "hidden": {
          "type": "boolean"
        },
        "label": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        }
      },
      "required": [
        "expression"
      ],
      "type": "object"
    },
    "#ProjectSemanticModelSpec": {
      "additionalProperties": false,
      "properties": {
        "dimensions": {
          "additionalProperties": false,
          "patternProperties": {
            "^[A-Za-z_][A-Za-z0-9_]*$": {
              "$ref": "#/$defs/%23SemanticDimension"
            }
          },
          "type": "object"
        },
        "measures": {
          "additionalProperties": false,
          "patternProperties": {
            "^[A-Za-z_][A-Za-z0-9_]*$": {
              "$ref": "#/$defs/%23Measure"
            }
          },
          "type": "object"
        },
        "metrics": {
          "additionalProperties": false,
          "patternProperties": {
            "^[A-Za-z_][A-Za-z0-9_]*$": {
              "$ref": "#/$defs/%23Metric"
            }
          },
          "type": "object"
        },
        "relationships": {
          "items": {
            "$ref": "#/$defs/%23Relationship"
          },
          "type": "array"
        },
        "tables": {
          "items": {
            "$ref": "#/$defs/%23Identifier"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "measures",
        "tables"
      ],
      "type": "object"
    },
    "#Relationship": {
      "additionalProperties": false,
      "properties": {
        "cardinality": {
          "enum": [
            "many_to_one",
            "one_to_one"
          ]
        },
        "description": {
          "type": "string"
        },
        "from": {
          "$ref": "#/$defs/%23FieldRef"
        },
        "id": {
          "$ref": "#/$defs/%23Identifier"
        },
        "to": {
          "$ref": "#/$defs/%23FieldRef"
        }
      },
      "required": [
        "cardinality",
        "from",
        "id",
        "to"
      ],
      "type": "object"
    },
    "#ResourceID": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$",
      "type": "string"
    },
    "#SemanticDimension": {
      "additionalProperties": false,
      "properties": {
        "bindings": {
          "additionalProperties": false,
          "patternProperties": {
            "^[A-Za-z_][A-Za-z0-9_]*$": {
              "additionalProperties": false,
              "properties": {
                "field": {
                  "$ref": "#/$defs/%23FieldRef"
                },
                "path": {
                  "items": {
                    "$ref": "#/$defs/%23Identifier"
                  },
                  "type": "array"
                }
              },
              "required": [
                "field"
              ],
              "type": "object"
            }
          },
          "type": "object"
        },
        "description": {
          "type": "string"
        },
        "grains": {
          "items": {
            "enum": [
              "day",
              "week",
              "month",
              "quarter",
              "year"
            ]
          },
          "type": "array"
        },
        "label": {
          "type": "string"
        },
        "type": {
          "enum": [
            "string",
            "number",
            "boolean",
            "date",
            "timestamp"
          ]
        }
      },
      "required": [
        "bindings",
        "type"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "$ref": "#/$defs/%23APIVersion"
    },
    "kind": {
      "const": "SemanticModel"
    },
    "metadata": {
      "$ref": "#/$defs/%23Metadata"
    },
    "spec": {
      "$ref": "#/$defs/%23ProjectSemanticModelSpec"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
