{
  "$defs": {
    "#APIVersion": {
      "const": "leapview.dev/v1"
    },
    "#AnyObject": {
      "additionalProperties": true,
      "type": "object"
    },
    "#Identifier": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
      "type": "string"
    },
    "#Metadata": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/%23ResourceID"
        },
        "owner": {
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "title": {
          "type": "string"
        },
        "workspace": {
          "$ref": "#/$defs/%23ResourceID"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "#ResourceID": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$",
      "type": "string"
    },
    "#Source": {
      "additionalProperties": false,
      "properties": {
        "connection": {
          "$ref": "#/$defs/%23Identifier"
        },
        "description": {
          "type": "string"
        },
        "fields": {
          "additionalProperties": false,
          "patternProperties": {
            "^[A-Za-z_][A-Za-z0-9_]*$": {
              "additionalProperties": false,
              "properties": {
                "description": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          "type": "object"
        },
        "format": {
          "enum": [
            "csv",
            "json",
            "parquet",
            "excel",
            "text",
            "blob",
            "vortex",
            "delta",
            "iceberg",
            "lance"
          ]
        },
        "object": {
          "type": "string"
        },
        "options": {
          "$ref": "#/$defs/%23AnyObject"
        },
        "path": {
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "$ref": "#/$defs/%23APIVersion"
    },
    "kind": {
      "const": "Source"
    },
    "metadata": {
      "$ref": "#/$defs/%23Metadata"
    },
    "spec": {
      "$ref": "#/$defs/%23Source"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
