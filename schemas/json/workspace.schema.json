{
  "$defs": {
    "#APIVersion": {
      "const": "leapview.dev/v1"
    },
    "#IncludeList": {
      "additionalProperties": false,
      "properties": {
        "include": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "include"
      ],
      "type": "object"
    },
    "#Metadata": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/%23ResourceID"
        },
        "owner": {
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "title": {
          "type": "string"
        },
        "workspace": {
          "$ref": "#/$defs/%23ResourceID"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "#ResourceID": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "$ref": "#/$defs/%23APIVersion"
    },
    "kind": {
      "const": "Workspace"
    },
    "metadata": {
      "$ref": "#/$defs/%23Metadata"
    },
    "spec": {
      "additionalProperties": false,
      "properties": {
        "access": {
          "$ref": "#/$defs/%23IncludeList"
        },
        "dashboards": {
          "$ref": "#/$defs/%23IncludeList"
        },
        "models": {
          "$ref": "#/$defs/%23IncludeList"
        },
        "refreshPipelines": {
          "$ref": "#/$defs/%23IncludeList"
        },
        "semanticModels": {
          "$ref": "#/$defs/%23IncludeList"
        },
        "uses": {
          "additionalProperties": false,
          "properties": {
            "sources": {
              "items": {
                "$ref": "#/$defs/%23ResourceID"
              },
              "type": "array"
            }
          },
          "required": [
            "sources"
          ],
          "type": "object"
        }
      },
      "required": [
        "access",
        "dashboards",
        "models",
        "semanticModels",
        "uses"
      ],
      "type": "object"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
