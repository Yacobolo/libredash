{
  "$defs": {
    "#APIVersion": {
      "const": "leapview.dev/v1"
    },
    "#Metadata": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/%23ResourceID"
        },
        "owner": {
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "title": {
          "type": "string"
        },
        "workspace": {
          "$ref": "#/$defs/%23ResourceID"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "#ResourceID": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "$ref": "#/$defs/%23APIVersion"
    },
    "kind": {
      "const": "RefreshPipeline"
    },
    "metadata": {
      "$ref": "#/$defs/%23Metadata"
    },
    "spec": {
      "additionalProperties": false,
      "properties": {
        "on": {
          "additionalProperties": false,
          "properties": {
            "schedule": {
              "items": {
                "additionalProperties": false,
                "properties": {
                  "cron": {
                    "not": {
                      "const": ""
                    },
                    "type": "string"
                  },
                  "timezone": {
                    "not": {
                      "const": ""
                    },
                    "type": "string"
                  }
                },
                "required": [
                  "cron"
                ],
                "type": "object"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "semanticModel": {
          "$ref": "#/$defs/%23ResourceID"
        }
      },
      "required": [
        "semanticModel"
      ],
      "type": "object"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
