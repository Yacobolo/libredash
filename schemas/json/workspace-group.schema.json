{
  "$defs": {
    "#APIVersion": {
      "const": "leapview.dev/v1"
    },
    "#Metadata": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/%23ResourceID"
        },
        "owner": {
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "title": {
          "type": "string"
        },
        "workspace": {
          "$ref": "#/$defs/%23ResourceID"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "#ResourceID": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "$ref": "#/$defs/%23APIVersion"
    },
    "kind": {
      "const": "WorkspaceGroup"
    },
    "metadata": {
      "$ref": "#/$defs/%23Metadata"
    },
    "spec": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "members": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "displayName": {
                "type": "string"
              },
              "email": {
                "type": "string"
              },
              "principalId": {
                "$ref": "#/$defs/%23ResourceID"
              }
            },
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
